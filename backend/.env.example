# ── Lwang Black Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your real values.
# Keys marked [REQUIRED] must be set for production. Others have safe defaults for dev.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # set to "production" on the server

# ── PostgreSQL [REQUIRED for real data] ──────────────────────────────────────
# Provide either DATABASE_URL (preferred) OR individual DB_* vars.
# Without this the server runs in in-memory demo mode (data lost on restart).
DATABASE_URL=postgres://lwangblack:lwangblack_secret@localhost:5432/lwangblack
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=lwangblack
# DB_USER=lwangblack
# DB_PASSWORD=lwangblack_secret

# ── Redis (optional but recommended) ─────────────────────────────────────────
# Required for server-side session revocation (logout across devices) and cart caching.
REDIS_URL=redis://localhost:6379

# ── JWT [REQUIRED — change defaults before going live] ───────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-too
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=7d

# ── Admin Credentials ─────────────────────────────────────────────────────────
# Default password used when seeding admin users. Change after first login.
DEFAULT_ADMIN_PASSWORD=lwangblack2024

# ── Stripe (Payments + Manager Subscriptions) [REQUIRED for payments] ─────────
# https://dashboard.stripe.com/developers/api-keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_MODE=test                  # set to "live" in production
# Webhook URL to register in Stripe Dashboard → Webhooks:
#   https://yourdomain.com/api/payments/stripe-webhook
# Events to enable: checkout.session.completed, payment_intent.succeeded, payment_intent.payment_failed

# ── Manager Subscription Pricing ─────────────────────────────────────────────
# USD whole dollars. Defaults to $99/month if not set.
MANAGER_SUBSCRIPTION_PRICE=99
# Trial days before first charge (0 = no trial)
MANAGER_SUBSCRIPTION_TRIAL_DAYS=0

# ── PayPal [REQUIRED for AU/US/GB/CA/NZ/JP card payments] ────────────────────
# https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox               # set to "live" in production (used by dynamic-config)
PAYPAL_LIVE=false                 # legacy alias — keep in sync with PAYPAL_MODE

# ── eSewa (Nepal — legacy fallback) ──────────────────────────────────────────
# https://esewa.com.np/epay/main
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_LIVE=false

# Cash on Delivery — comma-separated ISO-3166 alpha-2 codes, or "*" for all.
# Example: "NP,IN,BD" to restrict COD to Nepal/India/Bangladesh.
COD_ENABLED_COUNTRIES=*

# ── Logistics Carriers ────────────────────────────────────────────────────────
# Chit Chats — Canada https://chitchats.com/
# USPS Web Tools — United States https://registration.shippingapis.com/ (free)
USPS_USER_ID=
USPS_PASSWORD=
USPS_TEST_MODE=true          # set to false in production
USPS_FROM_ZIP=10001
USPS_FROM_STREET=135 King St
USPS_FROM_CITY=New York
USPS_FROM_STATE=NY
USPS_FROM_PHONE=

CHITCHATS_API_KEY=

# Australia Post — AU + International https://developers.auspost.com.au/
# For real labels you need a MyPost Business account (accountNumber + password)
# in addition to the developer API key.
AUSPOST_API_KEY=
AUSPOST_ACCOUNT_NUMBER=
AUSPOST_PASSWORD=

# NZ Post — New Zealand https://www.nzpost.co.nz/developer
# NZPOST_API_KEY is used for rate + tracking APIs.
# CLIENT_ID/SECRET/SITE_CODE are required for label generation (OAuth2).
NZPOST_API_KEY=
NZPOST_CLIENT_ID=
NZPOST_CLIENT_SECRET=
NZPOST_SITE_CODE=

# Japan Post — Japan https://www.post.japanpost.jp/
# JP Post has no public label API — labels are generated locally as PDFs
# alongside the counter slip. Admin provides the tracking number.
JAPANPOST_API_KEY=
JAPANPOST_ENABLED=true

# Pathao — Nepal https://pathao.com/
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_FROM_EMAIL=brewed@lwangblack.co
SENDGRID_FROM_NAME=Lwang Black

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=              # used by config/index.js
TWILIO_FROM_PHONE=               # used by dynamic-config.js (keep both in sync)

# ── Social Media ──────────────────────────────────────────────────────────────
# Facebook & Instagram — https://developers.facebook.com/apps/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PIXEL_ID=

# TikTok — https://developers.tiktok.com/
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=

# ── Site / CORS / Frontend (split deploy: Render API + Vercel site) ──────────
SITE_URL=https://www.lwangblack.co
# Public storefront URL (used for eSewa/Khalti return URLs). Set to your Vercel production URL or custom domain.
FRONTEND_URL=https://www.lwangblack.co
# Comma-separated browser origins allowed to call this API. Include your Vercel URL(s) and local dev ports.
# Wildcard *.vercel.app / *.onrender.com are also allowed in code for previews.
CORS_ORIGIN=https://www.lwangblack.co,https://lwangblack.co,http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Firebase (legacy — optional) ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Optional: Vercel serverless proxy (lib/api/*.js) if you still proxy /api on Vercel ─
# Not used when the browser calls Render directly (recommended: set LWB_API_BASE on Vercel build).
BACKEND_URL=https://your-service.onrender.com
