{
  "name": "lwang-black",
  "version": "1.0.0",
  "description": "Lwang Black ecommerce backend",
  "main": "api/server.js",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "build": "npm --prefix admin-dashboard ci --prefer-offline && npm --prefix admin-dashboard run build",
    "backend:dev": "npm --prefix backend run dev",
    "admin:dev": "npm --prefix admin-dashboard run dev -- --host --port 5173"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "firebase-admin": "^12.7.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "stripe": "^14.6.0"
  },
  "engines": {
    "node": "24.x"
  }
}
