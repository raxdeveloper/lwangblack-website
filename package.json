{
  "name": "lwang-black",
  "version": "1.0.0",
  "description": "Lwang Black ecommerce — static storefront + admin dashboard + API proxy",
  "main": "api/index.js",
  "scripts": {
    "build":       "node scripts/build.js",
    "dev":         "npm --prefix backend run dev",
    "dev:admin":   "npm --prefix admin-dashboard run dev -- --host --port 5173",
    "dev:vercel":  "vercel dev",
    "deploy":      "vercel --prod",
    "backend:dev": "npm --prefix backend run dev"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "firebase-admin": "^12.7.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "stripe": "^14.6.0"
  },
  "engines": {
    "node": "22.x"
  }
}
